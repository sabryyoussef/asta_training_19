<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nelc_xapi_console_settings_tree" model="ir.ui.view">
        <field name="name">nelc.xapi.console.settings.tree</field>
        <field name="model">nelc.xapi.console.settings</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="lrs_endpoint"/>
                <field name="platform_key"/>
                <field name="last_synced_at"/>
                <field name="last_applied_at"/>
            </list>
        </field>
    </record>

    <record id="view_nelc_xapi_console_settings_form" model="ir.ui.view">
        <field name="name">nelc.xapi.console.settings.form</field>
        <field name="model">nelc.xapi.console.settings</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_from_parameters" type="object" string="Sync From Parameters" class="btn-primary"/>
                    <button name="action_apply_to_parameters" type="object" string="Apply To Parameters" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group string="LRS Configuration" col="2">
                        <field name="lrs_endpoint"/>
                        <field name="lrs_auth_header" password="True"/>
                        <field name="platform_key"/>
                        <field name="odoo_base_url"/>
                    </group>
                    <group string="Platform Display Names" col="2">
                        <field name="platform_name_ar"/>
                        <field name="platform_name_en"/>
                    </group>
                    <group string="Audit" col="2">
                        <field name="last_synced_at" readonly="1"/>
                        <field name="last_applied_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nelc_xapi_console_settings" model="ir.actions.act_window">
        <field name="name">NELC xAPI Settings</field>
        <field name="res_model">nelc.xapi.console.settings</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
