# NELC xAPI Admission – Environment Variables
#
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file to source control.
#
# On Odoo.sh: set these as Environment Variables in the project settings
# (Project → Settings → Environment Variables).  The nelc_xapi_admission
# module reads them via ir.config_parameter (see README.md for the mapping).

# Full HTTPS URL of the NELC LRS statements endpoint
# Example: https://lrs.nelc.gov.sa/xapi/statements
NELC_LRS_ENDPOINT=

# Complete Authorization header value sent with every xAPI request.
# Examples:
#   Basic base64encodedusernamepassword==
#   Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NELC_LRS_AUTH_HEADER=

# Platform key assigned by NELC for your institution
# Example: MGMT-003
NELC_PLATFORM_KEY=

# Public base URL of this Odoo instance (used to build stable xAPI object IDs)
# Example: https://myinstitution.odoo.com
# Leave empty to use the value already configured in Odoo (web.base.url).
ODOO_BASE_URL=
